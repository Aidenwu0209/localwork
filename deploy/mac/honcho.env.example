# Honcho config for DejaView (task M2.4/M2.5). Copy to honcho.env (gitignored) next to
# compose.honcho.yml. All inference routes through the LiteLLM gateway using logical
# model names (brain/perceive/fast/embed); no real API keys exist anywhere.
# From inside containers, the Mac host is host.docker.internal.

LOG_LEVEL=INFO
AUTH_USE_AUTH=false

# ---- data layer (deploy/mac/compose.data.yml) ----
DB_CONNECTION_URI=postgresql+psycopg://dejaview:dejaview@host.docker.internal:5433/honcho
CACHE_ENABLED=true
CACHE_URL=redis://host.docker.internal:6380/0?suppress=true
VECTOR_STORE_TYPE=pgvector
VECTOR_STORE_MIGRATED=false

# ---- LLM provider: dummy key, llama.cpp/LiteLLM do not validate it ----
LLM_OPENAI_API_KEY=local-dev

# ---- embeddings: Qwen3-Embedding-0.6B via gateway (1024 dims) ----
EMBED_MESSAGES=true
EMBEDDING_VECTOR_DIMENSIONS=1024
EMBEDDING_MODEL_CONFIG__TRANSPORT=openai
EMBEDDING_MODEL_CONFIG__MODEL=embed
EMBEDDING_MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1

# ---- deriver: high-frequency fact extraction -> perceive (E4B); switch to `fast`
#      with one line if T0.9 A/B passes ----
DERIVER_MODEL_CONFIG__TRANSPORT=openai
DERIVER_MODEL_CONFIG__MODEL=perceive
DERIVER_MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1
DERIVER_WORKERS=1
DERIVER_MODEL_CONFIG__MAX_OUTPUT_TOKENS=2048

# ---- dialectic: user-model Q&A -> brain (dev: E4B dual-mapped; S2: ThinkingCap-27B) ----
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__MODEL=brain
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1
DIALECTIC_LEVELS__low__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__low__MODEL_CONFIG__MODEL=brain
DIALECTIC_LEVELS__low__MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1
DIALECTIC_LEVELS__medium__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__medium__MODEL_CONFIG__MODEL=brain
DIALECTIC_LEVELS__medium__MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1
DIALECTIC_LEVELS__high__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__high__MODEL_CONFIG__MODEL=brain
DIALECTIC_LEVELS__high__MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1
DIALECTIC_LEVELS__max__MODEL_CONFIG__TRANSPORT=openai
DIALECTIC_LEVELS__max__MODEL_CONFIG__MODEL=brain
DIALECTIC_LEVELS__max__MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1

# ---- summaries: mid-frequency rollups -> perceive ----
SUMMARY_MODEL_CONFIG__TRANSPORT=openai
SUMMARY_MODEL_CONFIG__MODEL=perceive
SUMMARY_MODEL_CONFIG__OVERRIDES__BASE_URL=http://host.docker.internal:4000/v1

# ---- dreams: disabled during dev (compute budget); revisit on the server ----
DREAM_ENABLED=false

# ---- observability: local only, no external telemetry ----
METRICS_ENABLED=true
TELEMETRY_ENABLED=false
SENTRY_ENABLED=false
