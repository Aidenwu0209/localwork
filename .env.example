# ---- inference (all app code speaks logical model names via the gateway) ----
# Logical names: brain / perceive / sentinel / fast / embed  (optional: rerank)
GATEWAY_URL=http://127.0.0.1:4000/v1
OCR_URL=http://127.0.0.1:8006

# ---- data layer (Mac is the data-sovereignty side) ----
TIMELINE_DB_URL=postgresql://dejaview:dejaview@127.0.0.1:5433/dejaview
HONCHO_DB_URI=postgresql+psycopg://dejaview:dejaview@127.0.0.1:5433/honcho
REDIS_URL=redis://127.0.0.1:6380/0

# All user artifacts (screenshots, audio, docs) live under one portable root.
DATA_ROOT=~/dejaview-data

# ---- dev-mode inference (Apple M5 16GB: start instances on demand, never all at once) ----
DEV_MODELS_DIR=~/Projects/Aidenwu0209/models/dejaview
